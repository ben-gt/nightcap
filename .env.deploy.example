# Copy to .env.deploy and fill in real values. .env.deploy is gitignored.
# These are baked into the Expo web bundle at build time via Docker build args.
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-client-id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://your-api-identifier

# Airwallex payments. Leave blank to run in MOCK mode (no real charges).
# All three must be set for live payments to activate.
# - ENV: `demo` for sandbox, `prod` for production
# - PUBLISHABLE_KEY: from the Airwallex dashboard (safe to expose to clients)
# - PAYMENT_INTENT_ENDPOINT: your backend endpoint that creates an Airwallex
#   PaymentIntent and returns its { id, client_secret }. The Airwallex SECRET
#   key must live on that backend — never bake it into the Expo bundle.
EXPO_PUBLIC_AIRWALLEX_ENV=
EXPO_PUBLIC_AIRWALLEX_PUBLISHABLE_KEY=
EXPO_PUBLIC_PAYMENT_INTENT_ENDPOINT=
